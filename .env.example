# CF Worker URL (printed after: cd worker && npx wrangler deploy)
# GEMINI_API_KEY, CF_ACCOUNT_ID, CF_API_TOKEN are wrangler secrets — never put them here
VITE_CF_WORKER_URL=https://floatpad-crawler.your-subdomain.workers.dev

# Shared secret to authenticate frontend → worker requests
# Generate: openssl rand -hex 32
# Must match WORKER_SECRET set via: npx wrangler secret put WORKER_SECRET
VITE_WORKER_SECRET=your_shared_secret_here
